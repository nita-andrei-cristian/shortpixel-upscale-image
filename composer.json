{
    "repositories": [
        {
            "packagist.org": false,
            "type": "path",
            "url": "../modules/*",
	    "options": {
                "symlink": true
            }
        }
    ],
    "require": {
        "spui/notices":">=1.3",
        "spui/build" : "@dev",
				"spui/shortq": ">=1.0",
				"spui/replacer2": ">=2.0"
    },
    "require-dev": {
	"phpunit/phpunit": "^9",
	"mikey179/vfsstream": "^1",
	"10up/wp_mock": "@dev",
        "php-stubs/wp-cli-stubs": "^2.11"

    },
   "autoload": {
       "psr-4": { "SPUI\\" : "class" , "SPUI\\Tests\\" : "tests"}
   },
    "scripts": {
        "post-update-cmd" : "\\SPUI\\Build\\Build::BuildIt",
        "buildSP" : "\\SPUI\\Build\\Build::BuildIt",
        "buildLoader": "\\SPUI\\BuildAutoLoader::buildJSON"
    },
    "extra": {
         "targetNamespace" : "ShortPixel"
    }

}
